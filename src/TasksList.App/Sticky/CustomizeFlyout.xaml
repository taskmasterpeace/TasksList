<UserControl x:Class="TasksList.App.Sticky.CustomizeFlyout"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="326" Focusable="False">
    <UserControl.Resources>
        <Style x:Key="SwatchButton" TargetType="Button">
            <Setter Property="Width" Value="27" />
            <Setter Property="Height" Value="27" />
            <Setter Property="Margin" Value="3" />
            <Setter Property="BorderBrush" Value="#503A2E21" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Swatch" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Swatch" Property="BorderThickness" Value="3" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Swatch" Property="BorderBrush" Value="#FF111111" />
                                <Setter TargetName="Swatch" Property="BorderThickness" Value="2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="LightTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#FFFDF8" />
            <Setter Property="Foreground" Value="#30291F" />
            <Setter Property="BorderBrush" Value="#4A6B5942" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="7,5" />
        </Style>
        <Style x:Key="MiniButton" TargetType="Button">
            <Setter Property="Background" Value="#173D3222" />
            <Setter Property="Foreground" Value="#4B3E2C" />
            <Setter Property="BorderBrush" Value="#355B4831" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="9,6" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </UserControl.Resources>

    <Border Background="#FAF7F0" BorderBrush="#2A3B3124" BorderThickness="1"
            CornerRadius="12" Padding="16" MaxHeight="660">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="22" ShadowDepth="7" Opacity="0.28" />
        </Border.Effect>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="0,0,4,0">
                <TextBlock Text="M A K E   I T   Y O U R S" Foreground="#7B6546" FontSize="10"
                           FontWeight="Bold" />
                <Grid Margin="0,13,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Opacity" Foreground="#30291F" FontWeight="SemiBold" />
                    <TextBlock x:Name="OpacityValue" Grid.Column="1" Foreground="#7B6546"
                               FontWeight="Bold" />
                </Grid>
                <Slider x:Name="OpacitySlider" Minimum="20" Maximum="100" TickFrequency="5"
                        IsSnapToTickEnabled="True" ValueChanged="OpacitySliderChanged"
                        AutomationProperties.Name="Active opacity" />
                <Grid Margin="0,8,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Inactive opacity" Foreground="#554A3B" FontSize="11" />
                    <TextBlock x:Name="InactiveOpacityValue" Grid.Column="1" Foreground="#7B6546"
                               FontSize="11" FontWeight="Bold" />
                </Grid>
                <Slider x:Name="InactiveOpacitySlider" Minimum="20" Maximum="100" TickFrequency="5"
                        IsSnapToTickEnabled="True" ValueChanged="InactiveOpacitySliderChanged"
                        ToolTip="Opacity while this sticky is not focused"
                        AutomationProperties.Name="Inactive opacity" />

                <TextBlock Text="P A P E R" Foreground="#7B6546" FontSize="10" FontWeight="Bold"
                           Margin="0,16,0,8" />
                <UniformGrid Columns="8">
                    <Button Style="{StaticResource SwatchButton}" Background="#F4CE62" Tag="Butter" Click="PresetClick" ToolTip="Butter" AutomationProperties.Name="Butter paper" />
                    <Button Style="{StaticResource SwatchButton}" Background="#EFA66F" Tag="Peach" Click="PresetClick" ToolTip="Peach" AutomationProperties.Name="Peach paper" />
                    <Button Style="{StaticResource SwatchButton}" Background="#9FD4B5" Tag="Mint" Click="PresetClick" ToolTip="Mint" AutomationProperties.Name="Mint paper" />
                    <Button Style="{StaticResource SwatchButton}" Background="#A8C5E8" Tag="Sky" Click="PresetClick" ToolTip="Sky" AutomationProperties.Name="Sky paper" />
                    <Button Style="{StaticResource SwatchButton}" Background="#C7B4E5" Tag="Lavender" Click="PresetClick" ToolTip="Lavender" AutomationProperties.Name="Lavender paper" />
                    <Button Style="{StaticResource SwatchButton}" Background="#E7AFC0" Tag="Rose" Click="PresetClick" ToolTip="Rose" AutomationProperties.Name="Rose paper" />
                    <Button Style="{StaticResource SwatchButton}" Background="#24262D" Tag="Graphite" Click="PresetClick" ToolTip="Graphite" AutomationProperties.Name="Graphite paper" />
                    <Button Style="{StaticResource SwatchButton}" Background="#D9E4E7" Tag="Glass" Click="PresetClick" ToolTip="Glass" AutomationProperties.Name="Glass paper" />
                </UniformGrid>

                <TextBlock Text="CUSTOM COLORS" Foreground="#7B6546" FontSize="9" FontWeight="Bold"
                           Margin="0,15,0,6" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="BackgroundColorBox" Style="{StaticResource LightTextBox}"
                             ToolTip="Background #RRGGBB" TextChanged="ColorTextChanged" />
                    <TextBox x:Name="TextColorBox" Grid.Column="2" Style="{StaticResource LightTextBox}"
                             ToolTip="Text #RRGGBB" TextChanged="ColorTextChanged" />
                    <TextBox x:Name="AccentColorBox" Grid.Column="4" Style="{StaticResource LightTextBox}"
                             ToolTip="Accent #RRGGBB" TextChanged="ColorTextChanged" />
                </Grid>
                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="ContrastText" Foreground="#6A7659" FontSize="10"
                               VerticalAlignment="Center" Text="Contrast" />
                    <Button Grid.Column="1" Style="{StaticResource MiniButton}" Content="Apply colors"
                            Click="ApplyColorsClick" />
                </Grid>

                <TextBlock Text="T Y P O G R A P H Y" Foreground="#7B6546" FontSize="10"
                           FontWeight="Bold" Margin="0,16,0,7" />
                <ComboBox x:Name="FontFamilyBox" SelectionChanged="TypographyChanged" />
                <Grid Margin="0,7,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="FontSizeBox" SelectionChanged="TypographyChanged">
                        <ComboBoxItem Content="11" /><ComboBoxItem Content="12" />
                        <ComboBoxItem Content="13" /><ComboBoxItem Content="14" />
                        <ComboBoxItem Content="16" /><ComboBoxItem Content="18" />
                        <ComboBoxItem Content="22" /><ComboBoxItem Content="28" />
                    </ComboBox>
                    <ComboBox x:Name="FontWeightBox" Grid.Column="2" SelectionChanged="TypographyChanged">
                        <ComboBoxItem Content="400" Tag="Regular" />
                        <ComboBoxItem Content="500" Tag="Medium" />
                        <ComboBoxItem Content="600" Tag="Semibold" />
                        <ComboBoxItem Content="700" Tag="Bold" />
                    </ComboBox>
                    <ComboBox x:Name="LineSpacingBox" Grid.Column="4" SelectionChanged="TypographyChanged">
                        <ComboBoxItem Content="1.0" /><ComboBoxItem Content="1.2" />
                        <ComboBoxItem Content="1.4" /><ComboBoxItem Content="1.6" />
                        <ComboBoxItem Content="2.0" />
                    </ComboBox>
                </Grid>

                <TextBlock Text="L A Y O U T   &amp;   C H R O M E" Foreground="#7B6546" FontSize="10"
                           FontWeight="Bold" Margin="0,16,0,7" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="DensityBox" SelectionChanged="DensityChanged">
                        <ComboBoxItem Content="Compact" /><ComboBoxItem Content="Comfortable" />
                        <ComboBoxItem Content="Spacious" />
                    </ComboBox>
                    <ComboBox x:Name="ToolbarBox" Grid.Column="2" SelectionChanged="ToolbarChanged">
                        <ComboBoxItem Content="Always" /><ComboBoxItem Content="Hover" />
                        <ComboBoxItem Content="Focused" /><ComboBoxItem Content="Hidden" />
                    </ComboBox>
                </Grid>
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="72" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="100" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Shadow" Foreground="#4A4032" VerticalAlignment="Center" />
                    <Slider x:Name="ShadowSlider" Grid.Column="1" Minimum="0" Maximum="100"
                            TickFrequency="10" ValueChanged="DecorationChanged" />
                    <ComboBox x:Name="CornerBox" Grid.Column="3" SelectionChanged="DecorationChanged">
                        <ComboBoxItem Content="Square" /><ComboBoxItem Content="Soft" />
                        <ComboBoxItem Content="Round" />
                    </ComboBox>
                </Grid>
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <CheckBox x:Name="BorderCheck" Content="Border" Foreground="#4A4032"
                              Checked="DecorationChanged" Unchecked="DecorationChanged" />
                    <CheckBox x:Name="TextureCheck" Grid.Column="1" Content="Paper texture"
                              Foreground="#4A4032" Checked="DecorationChanged" Unchecked="DecorationChanged" />
                </Grid>

                <TextBlock Text="N A M E D   S T Y L E S" Foreground="#7B6546" FontSize="10"
                           FontWeight="Bold" Margin="0,17,0,7" />
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="8" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <ComboBox x:Name="NamedStyleBox" DisplayMemberPath="Name" />
                    <Button Grid.Column="2" Style="{StaticResource MiniButton}" Content="Apply"
                            Click="ApplyNamedStyleClick" />
                </Grid>
                <Grid Margin="0,7,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="8" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <TextBox x:Name="StyleNameBox" Style="{StaticResource LightTextBox}" ToolTip="Style name" />
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <CheckBox x:Name="DefaultStyleCheck" Content="Default" Foreground="#4A4032"
                                  VerticalAlignment="Center" Margin="0,0,7,0" />
                        <Button Style="{StaticResource MiniButton}" Content="Save" Click="SaveNamedStyleClick" />
                    </StackPanel>
                </Grid>

                <Grid Margin="0,15,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <TextBlock Text="Ctrl + wheel changes opacity" Foreground="#8A7659" FontSize="10"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="1" Style="{StaticResource MiniButton}" Content="Reset appearance"
                            Click="ResetClick" />
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
