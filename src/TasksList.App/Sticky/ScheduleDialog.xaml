<Window x:Class="TasksList.App.Sticky.ScheduleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Choose a time" Width="360" Height="300" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False"
        WindowStyle="SingleBorderWindow" AllowsTransparency="False"
        Background="{StaticResource CanvasBrush}" KeyboardNavigation.TabNavigation="Local">
    <Border Background="{StaticResource CanvasBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
            CornerRadius="10" Padding="22">
        <StackPanel>
            <TextBlock x:Name="HeadingText" Text="Choose a date and time" FontSize="20"
                       FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
            <TextBlock Text="Task'sList uses your local Windows time zone." Foreground="{StaticResource MutedTextBrush}"
                       Margin="0,5,0,18" />
            <DatePicker x:Name="DateBox" AutomationProperties.Name="Reminder date" />
            <TextBox x:Name="TimeBox" Margin="0,9,0,0" Text="08:00"
                     AutomationProperties.Name="Reminder time"
                     ToolTip="Time in 24-hour HH:mm format" />
            <StackPanel x:Name="AttentionPanel" Margin="0,14,0,0">
                <TextBlock Text="Attention" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" />
                <StackPanel Orientation="Horizontal" Margin="0,7,0,0">
                    <CheckBox x:Name="SoundCheck" Content="Play sound" IsChecked="True" Margin="0,0,20,0" />
                    <CheckBox x:Name="PulseCheck" Content="Pulse note" IsChecked="True" />
                </StackPanel>
                <CheckBox x:Name="TopmostCheck" Content="Keep note on top until acknowledged"
                          IsChecked="True" Margin="0,8,0,0" />
            </StackPanel>
            <TextBlock x:Name="ErrorText" Foreground="{StaticResource DangerBrush}" Margin="0,10,0,0"
                       AutomationProperties.LiveSetting="Assertive"
                       Visibility="Collapsed" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Style="{StaticResource GhostButton}" Content="Cancel" IsCancel="True" Padding="14,8" Margin="0,0,8,0" />
                <Button Style="{StaticResource PrimaryButton}" Content="Schedule" Padding="14,8" Click="ScheduleClick" IsDefault="True" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
