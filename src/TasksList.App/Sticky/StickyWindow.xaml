<Window x:Class="TasksList.App.Sticky.StickyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Task'sList sticky"
        Width="360"
        Height="330"
        MinWidth="260"
        MinHeight="68"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        Topmost="True"
        ShowInTaskbar="False">
    <Border x:Name="Paper" Background="#F4CE62" CornerRadius="10"
            BorderBrush="#805C451A" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="5" Opacity="0.36" Color="#000000" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <RowDefinition x:Name="ContentRow" Height="*" />
                <RowDefinition x:Name="FooterRow" Height="34" />
            </Grid.RowDefinitions>
            <Border Grid.Row="0" BorderBrush="#315C451A" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBarMouseDown">
                <Grid Margin="12,0,7,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TitleBox" Background="Transparent" BorderThickness="0" Padding="0"
                             Foreground="#2E271C" FontWeight="Bold" FontSize="14" VerticalContentAlignment="Center"
                             TextChanged="ContentChanged" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="PinButton" Content="●" Width="30" Height="30" ToolTip="Always on top"
                                Foreground="#315D4A" Background="Transparent" BorderThickness="0" Cursor="Hand"
                                Click="PinClick" />
                        <Button Content="—" Width="30" Height="30" ToolTip="Roll up"
                                Foreground="#5A4933" Background="Transparent" BorderThickness="0" Cursor="Hand"
                                Click="RollClick" />
                        <Button Content="×" Width="30" Height="30" ToolTip="Close sticky"
                                Foreground="#5A4933" Background="Transparent" BorderThickness="0" Cursor="Hand"
                                Click="CloseClick" />
                    </StackPanel>
                </Grid>
            </Border>
            <Grid Grid.Row="1">
                <TextBox x:Name="MarkdownBox" AcceptsReturn="True" AcceptsTab="True"
                         TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Background="Transparent" Foreground="#3A3022" BorderThickness="0"
                         Padding="16,13" FontFamily="Aptos, Segoe UI" FontSize="13"
                         TextChanged="ContentChanged" />
                <FlowDocumentScrollViewer x:Name="PreviewViewer" Visibility="Collapsed"
                                          Background="Transparent" Foreground="#3A3022"
                                          VerticalScrollBarVisibility="Auto" IsToolBarVisible="False" />
            </Grid>
            <Grid Grid.Row="2" Margin="12,0,10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="ContextText" Text="UNATTACHED" Foreground="#826C4D"
                               FontSize="9" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Button Content="ATTACH" Foreground="#5C4930" Background="#18FFFFFF"
                            BorderThickness="0" Padding="7,3" Margin="8,0,0,0" FontSize="9" FontWeight="Bold"
                            Cursor="Hand" Click="AttachClick" ToolTip="Attach this sticky to the last application you were using" />
                    <Button x:Name="ModeButton" Content="PREVIEW" Foreground="#5C4930" Background="#18FFFFFF"
                            BorderThickness="0" Padding="7,3" Margin="9,0,0,0" FontSize="9" FontWeight="Bold"
                            Cursor="Hand" Click="ModeClick" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="SaveText" Text="SAVED" Foreground="#47705D" FontSize="9"
                               FontWeight="Bold" Margin="0,0,9,0" />
                    <TextBlock Text="↘" Foreground="#826C4D" FontSize="11" ToolTip="Resize from the corner" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
