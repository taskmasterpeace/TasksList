<Window x:Class="TasksList.App.Settings.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Task'sList Settings" Width="590" Height="680"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Text="Settings" FontSize="28" FontWeight="Bold" />
            <TextBlock Text="Tune desktop behavior and recovery-safe global shortcuts."
                       Foreground="{StaticResource MutedTextBrush}" Margin="0,5,0,20" />
        </StackPanel>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,8,0">
                <TextBlock Text="Sticky behavior" FontWeight="SemiBold" FontSize="16" />
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="190" /></Grid.ColumnDefinitions>
                    <TextBlock Text="Snap tolerance" VerticalAlignment="Center" />
                    <Slider x:Name="SnapSlider" Grid.Column="1" Minimum="0" Maximum="40"
                            TickFrequency="1" IsSnapToTickEnabled="True" />
                </Grid>
                <CheckBox x:Name="ReduceMotionCheck" Content="Reduce motion and disable focus fades" Margin="0,13,0,0" />
                <CheckBox x:Name="PauseMonitoringCheck" Content="Pause clipboard monitoring" Margin="0,10,0,0" />
                <CheckBox x:Name="PromoteDuplicatesCheck" Content="Promote repeated copies instead of adding duplicates" Margin="0,10,0,0" />
                <TextBlock Text="Excluded clipboard applications (one executable per line)"
                           Foreground="{StaticResource MutedTextBrush}" Margin="0,14,0,6" />
                <TextBox x:Name="ExcludedAppsBox" AcceptsReturn="True" Height="74"
                         VerticalScrollBarVisibility="Auto" ToolTip="Example: KeePass.exe" />

                <TextBlock Text="Global shortcuts" FontWeight="SemiBold" FontSize="16" Margin="0,26,0,6" />
                <TextBlock Text="Use forms such as Ctrl+Shift+V. Ghost recovery cannot be removed."
                           Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,12" />
                <ItemsControl x:Name="HotkeyRows">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="210" /></Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Label}" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock x:Name="ErrorText" Foreground="#F29A8A" TextWrapping="Wrap"
                           Visibility="Collapsed" Margin="0,12,0,0" />
            </StackPanel>
        </ScrollViewer>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Cancel" IsCancel="True" Padding="15,9" Margin="0,0,8,0" />
            <Button Content="Save settings" IsDefault="True" Padding="15,9" Click="SaveClick" />
        </StackPanel>
    </Grid>
</Window>
