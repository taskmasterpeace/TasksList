<Window x:Class="TasksList.App.Capture.CaptureOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select capture region"
        WindowStyle="None" AllowsTransparency="True" Background="#77000000"
        Topmost="True" ShowInTaskbar="False" ResizeMode="NoResize"
        Cursor="Cross" KeyDown="OverlayKeyDown"
        MouseLeftButtonDown="OverlayMouseDown"
        MouseMove="OverlayMouseMove"
        MouseLeftButtonUp="OverlayMouseUp">
    <Canvas x:Name="Surface">
        <Border x:Name="Selection" Visibility="Collapsed" BorderBrush="#F19A4B" BorderThickness="2"
                Background="#16FFFFFF" CornerRadius="2">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="12" ShadowDepth="2" Opacity="0.6" />
            </Border.Effect>
        </Border>
        <Border Canvas.Left="24" Canvas.Top="24" Background="#E91E2225" CornerRadius="10" Padding="13,9">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Drag to capture" FontWeight="Bold" />
                <TextBlock Text="  ·  Esc to cancel" Foreground="#A9B2B1" />
            </StackPanel>
        </Border>
    </Canvas>
</Window>

