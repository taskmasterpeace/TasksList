<Window x:Class="TasksList.App.Clipboard.ClipboardEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit clip" Width="520" Height="440" WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="22">
        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Text="Edit clipboard item" FontSize="22" FontWeight="SemiBold" />
            <TextBox x:Name="TitleBox" Margin="0,14,0,10" ToolTip="Optional title"
                     AutomationProperties.Name="Clipboard item title" />
        </StackPanel>
        <TextBox x:Name="ContentBox" Grid.Row="1" AcceptsReturn="True" TextWrapping="Wrap"
                 AutomationProperties.Name="Clipboard item content"
                 VerticalScrollBarVisibility="Auto" />
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Cancel" IsCancel="True" Padding="14,8" Margin="0,0,8,0" />
            <Button Content="Save" IsDefault="True" Padding="14,8" Click="SaveClick" />
        </StackPanel>
    </Grid>
</Window>
