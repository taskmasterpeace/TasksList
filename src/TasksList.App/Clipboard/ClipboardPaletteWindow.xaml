<Window x:Class="TasksList.App.Clipboard.ClipboardPaletteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Task'sList Clipboard Palette" Width="940" Height="610" MinWidth="720" MinHeight="460"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="CanResizeWithGrip" ShowInTaskbar="False" Topmost="True"
        PreviewKeyDown="WindowPreviewKeyDown">
    <Window.Resources>
        <Style x:Key="FilterToggle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="#B7C1C0" /><Setter Property="Background" Value="#252A2E" />
            <Setter Property="BorderBrush" Value="#3A4247" /><Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" /><Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#333A3E" /></Trigger>
                <Trigger Property="IsChecked" Value="True"><Setter Property="Background" Value="#4A3323" /><Setter Property="Foreground" Value="#F7B36D" /><Setter Property="BorderBrush" Value="#A8672D" /></Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Foreground" Value="#E8E4DC" /><Setter Property="Background" Value="#2A3034" />
            <Setter Property="BorderBrush" Value="#41494E" /><Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="11,7" /><Setter Property="Margin" Value="0,0,7,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#394044" /><Setter Property="BorderBrush" Value="#687277" /></Trigger>
                <Trigger Property="IsPressed" Value="True"><Setter Property="Opacity" Value="0.72" /></Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Border Background="#F217191B" BorderBrush="#505A6165" BorderThickness="1" CornerRadius="14">
        <Border.Effect><DropShadowEffect BlurRadius="28" ShadowDepth="9" Opacity="0.55" /></Border.Effect>
        <Grid>
            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
            <Grid Margin="20,18,20,10">
                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <Border Width="36" Height="36" CornerRadius="10" Background="#4A3323" Margin="0,0,12,0">
                    <TextBlock Text="⌘" Foreground="#F19A4B" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBox x:Name="SearchBox" Grid.Column="1" FontSize="16" Padding="12,9"
                         AutomationProperties.Name="Search clipboard history"
                         TextChanged="SearchChanged" PreviewKeyDown="SearchKeyDown" />
                <Button Grid.Column="2" Content="×" Width="38" Height="38" Margin="10,0,0,0"
                        Style="{StaticResource ActionButton}" Click="HideClick" ToolTip="Close (Esc)"
                        AutomationProperties.Name="Close clipboard palette" />
            </Grid>

            <Grid Grid.Row="1" Margin="20,0,20,12">
                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="12" /><ColumnDefinition Width="150" /><ColumnDefinition Width="8" /><ColumnDefinition Width="150" /><ColumnDefinition Width="8" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                <ToggleButton x:Name="FavoriteFilter" Content="★ Favorites" Style="{StaticResource FilterToggle}" Checked="FilterChanged" Unchecked="FilterChanged" />
                <ToggleButton x:Name="UsedFilter" Grid.Column="1" Content="Used" Style="{StaticResource FilterToggle}" Checked="FilterChanged" Unchecked="FilterChanged" />
                <ToggleButton x:Name="UnfiledFilter" Grid.Column="2" Content="Unfiled" Style="{StaticResource FilterToggle}" Checked="FilterChanged" Unchecked="FilterChanged" />
                <ComboBox x:Name="TypeFilter" Grid.Column="4" SelectionChanged="FilterChanged">
                    <ComboBoxItem Content="All types" Tag="All" IsSelected="True" />
                    <ComboBoxItem Content="Text" Tag="Text" /><ComboBoxItem Content="HTML" Tag="Html" />
                    <ComboBoxItem Content="Rich text" Tag="RichText" /><ComboBoxItem Content="Markdown" Tag="Markdown" />
                    <ComboBoxItem Content="Images" Tag="Image" /><ComboBoxItem Content="Files" Tag="Files" />
                </ComboBox>
                <ComboBox x:Name="DateFilter" Grid.Column="6" SelectionChanged="FilterChanged">
                    <ComboBoxItem Content="Any date" Tag="All" IsSelected="True" />
                    <ComboBoxItem Content="Today" Tag="Today" /><ComboBoxItem Content="Last 7 days" Tag="7" />
                    <ComboBoxItem Content="Last 30 days" Tag="30" />
                </ComboBox>
                <ComboBox x:Name="SourceFilter" Grid.Column="8" DisplayMemberPath="DisplayName"
                          SelectionChanged="FilterChanged" ToolTip="Source application" />
            </Grid>

            <Grid Grid.Row="2" Margin="20,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="1.05*" /><ColumnDefinition Width="12" /><ColumnDefinition Width="0.95*" /></Grid.ColumnDefinitions>
                <Border Background="#E622272A" BorderBrush="#3A4247" BorderThickness="1" CornerRadius="10">
                    <ListBox x:Name="ClipList" Background="Transparent" BorderThickness="0" SelectionMode="Extended"
                             SelectionChanged="ClipSelectionChanged" PreviewKeyDown="ListKeyDown"
                             PreviewMouseLeftButtonDown="ClipMouseDown" PreviewMouseMove="ClipMouseMove"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="12,10" /><Setter Property="Margin" Value="4,3" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Background" Value="Transparent" />
                                <Style.Triggers><Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="#4A3323" /><Setter Property="Foreground" Value="#FFF3E5" /></Trigger></Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Heading}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Preview}" Foreground="#9DA9A9" Margin="0,4,0,0" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Meta}" Foreground="#71807E" FontSize="10" Margin="0,5,0,0" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding FavoriteGlyph}" Foreground="#F4B65D" FontSize="16" Margin="8,0,0,0" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
                <Border Grid.Column="2" Background="#E622272A" BorderBrush="#3A4247" BorderThickness="1" CornerRadius="10" Padding="18">
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                        <StackPanel>
                            <TextBlock x:Name="PreviewTitle" Text="Select a clipboard item" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap" />
                            <TextBlock x:Name="ProvenanceText" Foreground="#8FA09E" FontSize="11" Margin="0,7,0,12" TextWrapping="Wrap" />
                        </StackPanel>
                        <Grid Grid.Row="1">
                            <TextBox x:Name="PreviewText" IsReadOnly="True" AcceptsReturn="True"
                                     TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Background="#151719" />
                            <Border x:Name="PreviewImageHost" Background="#151719" CornerRadius="8" Visibility="Collapsed">
                                <Image x:Name="PreviewImage" Stretch="Uniform" Margin="8" />
                            </Border>
                        </Grid>
                        <Grid Grid.Row="2" Margin="0,12,0,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="8" /><ColumnDefinition Width="150" /></Grid.ColumnDefinitions>
                            <ComboBox x:Name="PlaceBox" DisplayMemberPath="Name" ToolTip="Assign selected clips to a Place or note" />
                            <Button Grid.Column="2" Content="Assign selected" Style="{StaticResource ActionButton}" Click="AssignClick" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="3" Margin="20,13,20,18">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Paste" Style="{StaticResource ActionButton}" Click="PasteClick" />
                    <Button Content="Plain" Style="{StaticResource ActionButton}" Click="PlainPasteClick" />
                    <Button Content="Copy" Style="{StaticResource ActionButton}" Click="CopyClick" />
                    <Button Content="Join + paste" Style="{StaticResource ActionButton}" Click="JoinedPasteClick" />
                    <Button Content="Make note" Style="{StaticResource ActionButton}" Click="MakeNoteClick" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="★" Width="42" Style="{StaticResource ActionButton}" Click="FavoriteClick" ToolTip="Favorite selected" />
                    <Button Content="Edit" Style="{StaticResource ActionButton}" Click="EditClick" />
                    <Button Content="Duplicate" Style="{StaticResource ActionButton}" Click="DuplicateClick" />
                    <Button Content="Delete" Style="{StaticResource ActionButton}" Click="DeleteClick" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
