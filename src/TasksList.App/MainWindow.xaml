<Window x:Class="TasksList.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Task'sList"
        Width="1240"
        Height="780"
        MinWidth="980"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        AllowDrop="True"
        DragOver="MarkdownDragOver"
        Drop="MarkdownDrop">
    <Border Background="{StaticResource CanvasBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="14">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="8" Opacity="0.45" Color="#000000" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="64" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBarMouseDown">
                <Grid Margin="20,0,10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Width="30" Height="30" CornerRadius="9" Background="{StaticResource PrimaryBrush}">
                            <TextBlock Text="T" Foreground="#251A0D" FontWeight="Bold" FontSize="17"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Task'sList" FontSize="17" FontWeight="Bold" />
                            <TextBlock Text="Everything remembers where it belongs" FontSize="11"
                                       Foreground="{StaticResource MutedTextBrush}" />
                        </StackPanel>
                    </Grid>
                    <TextBlock Grid.Column="1" x:Name="StatusText" Text="LOCAL · PRIVATE"
                               FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource GhostButton}" Content="—" Width="38" Height="36"
                                ToolTip="Minimize" Click="MinimizeClick" />
                        <Button Style="{StaticResource GhostButton}" Content="□" Width="38" Height="36"
                                ToolTip="Maximize" Click="MaximizeClick" />
                        <Button Style="{StaticResource GhostButton}" Content="×" Width="38" Height="36"
                                ToolTip="Close" Click="CloseClick" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="258" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="326" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="P L A C E S" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource MutedTextBrush}" Margin="6,2,0,12" />
                        <Button Grid.Row="1" Style="{StaticResource GhostButton}" HorizontalContentAlignment="Left"
                                Margin="0,0,0,12" Padding="10,9">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⌕" FontSize="18" Foreground="{StaticResource MutedTextBrush}" Margin="0,-2,9,0" />
                                <TextBlock Text="Find anything" Foreground="{StaticResource MutedTextBrush}" />
                                <TextBlock Text="  Ctrl+Space" FontSize="10" Foreground="#687274" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Button Style="{StaticResource GhostButton}" HorizontalContentAlignment="Left" Background="{StaticResource PrimarySoftBrush}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="◆" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,9,0" />
                                        <TextBlock Text="All notes" FontWeight="SemiBold" />
                                        <Border Background="#694621" CornerRadius="8" Margin="8,0,0,0" Padding="6,1">
                                            <TextBlock x:Name="NoteCountText" Text="0" FontSize="10" />
                                        </Border>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource GhostButton}" HorizontalContentAlignment="Left">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="▣" Foreground="#8EA7C8" Margin="0,0,9,0" />
                                        <TextBlock Text="Clipboard" />
                                        <TextBlock Text="  live" FontSize="10" Foreground="{StaticResource SuccessBrush}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource GhostButton}" HorizontalContentAlignment="Left">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="◫" Foreground="#B995D8" Margin="0,0,9,0" />
                                        <TextBlock Text="Unfiled" />
                                    </StackPanel>
                                </Button>
                                <TextBlock Text="A P P L I C A T I O N S" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource MutedTextBrush}" Margin="7,22,0,7" />
                                <Button Style="{StaticResource GhostButton}" HorizontalContentAlignment="Left">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="22" Height="22" CornerRadius="6" Background="#304A6C" Margin="0,0,9,0">
                                                <TextBlock Text="E" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock Text="Microsoft Edge" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <TextBlock Text="      Open now · Saved sessions" FontSize="10" Foreground="{StaticResource MutedTextBrush}" Margin="0,5,0,0" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource GhostButton}" HorizontalContentAlignment="Left">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="22" Height="22" CornerRadius="6" Background="#4B3C68" Margin="0,0,9,0">
                                            <TextBlock Text="&gt;_" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock Text="Developer workspace" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource GhostButton}" HorizontalContentAlignment="Left">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="22" Height="22" CornerRadius="6" Background="#315C66" Margin="0,0,9,0">
                                            <TextBlock Text="D" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock Text="Docker Desktop" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <TextBlock Text="M Y  G R O U P S" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource MutedTextBrush}" Margin="7,22,0,7" />
                                <Button Style="{StaticResource GhostButton}" HorizontalContentAlignment="Left">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="▾" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,7,0" />
                                        <TextBlock Text="Release research" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource GhostButton}" HorizontalContentAlignment="Left" Padding="28,7,10,7">
                                    <TextBlock Text="Read later" Foreground="{StaticResource MutedTextBrush}" />
                                </Button>
                                <Button Style="{StaticResource GhostButton}" HorizontalContentAlignment="Left" Padding="28,7,10,7">
                                    <TextBlock Text="Deployment references" Foreground="{StaticResource MutedTextBrush}" />
                                </Button>
                            </StackPanel>
                        </ScrollViewer>
                        <Button Grid.Row="3" Style="{StaticResource GhostButton}" HorizontalContentAlignment="Left"
                                Content="＋  New place" Foreground="{StaticResource MutedTextBrush}" />
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Margin="25,22">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Your working notes" FontSize="25" FontWeight="Bold" />
                            <TextBlock Text="Pinned to the work, not buried in an archive." Margin="0,5,0,0"
                                       Foreground="{StaticResource MutedTextBrush}" FontSize="13" />
                        </StackPanel>
                        <Button Grid.Column="1" Style="{StaticResource PrimaryButton}" Content="＋  New sticky"
                                VerticalAlignment="Center" Click="NewStickyClick" />
                    </Grid>
                    <Grid Grid.Row="1" Margin="0,20,0,16">
                        <TextBox x:Name="SearchBox" Height="38" TextChanged="SearchTextChanged"
                                 ToolTip="Search notes" />
                        <TextBlock Text="Search titles and note text…" Foreground="{StaticResource MutedTextBrush}"
                                   Margin="12,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="NotesList">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel ItemWidth="235" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource GhostButton}" Padding="0" Margin="0,0,12,12"
                                            Width="223" Height="180" HorizontalContentAlignment="Stretch"
                                            VerticalContentAlignment="Stretch" Click="OpenNoteClick" Tag="{Binding}">
                                        <Border Background="{Binding PaperBrush}" CornerRadius="10" Padding="15"
                                                BorderBrush="{Binding EdgeBrush}" BorderThickness="1">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="*" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Title}" Foreground="{Binding InkBrush}"
                                                               FontWeight="Bold" FontSize="14" TextTrimming="CharacterEllipsis" />
                                                    <Ellipse Grid.Column="1" Width="7" Height="7" Fill="{Binding StatusBrush}"
                                                             Margin="8,0,0,0" ToolTip="Always on top" />
                                                </Grid>
                                                <TextBlock Grid.Row="1" Text="{Binding Preview}" Foreground="{Binding MutedInkBrush}"
                                                           FontSize="12" TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                                                           Margin="0,11,0,8" MaxHeight="84" />
                                                <Grid Grid.Row="2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding SourceLabel}" Foreground="{Binding MutedInkBrush}"
                                                               FontSize="9" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Column="1" Text="OPEN ↗" Foreground="{Binding InkBrush}"
                                                               FontSize="9" FontWeight="Bold" />
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <Border Grid.Column="2" Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0">
                    <Grid Margin="19">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="C L I P B O A R D" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource MutedTextBrush}" />
                                <TextBlock Text="Source-aware history" FontSize="15" FontWeight="SemiBold" Margin="0,4,0,0" />
                            </StackPanel>
                            <Border Grid.Column="1" Background="#203E31" CornerRadius="8" Padding="8,3" VerticalAlignment="Top">
                                <TextBlock Text="LISTENING" FontSize="9" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" />
                            </Border>
                        </Grid>
                        <ScrollViewer Grid.Row="1" Grid.RowSpan="2" Margin="0,18,0,12"
                                      VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="ClipboardList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,9">
                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding FormatLabel}" FontSize="9" FontWeight="Bold"
                                                               Foreground="{StaticResource PrimaryBrush}" />
                                                    <TextBlock Grid.Column="1" Text="{Binding TimeLabel}" FontSize="9"
                                                               Foreground="{StaticResource MutedTextBrush}" />
                                                </Grid>
                                                <TextBlock Text="{Binding Preview}" TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                                                           MaxHeight="56" FontSize="12" Margin="0,8,0,9" />
                                                <TextBlock Text="{Binding SourceLabel}" TextTrimming="CharacterEllipsis"
                                                           FontSize="9" Foreground="{StaticResource MutedTextBrush}" />
                                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                    <Button Style="{StaticResource GhostButton}" Content="MAKE NOTE" FontSize="9"
                                                            Padding="8,4" Margin="0,0,4,0" Tag="{Binding}" Click="ClipToNoteClick" />
                                                    <Button Style="{StaticResource GhostButton}" Content="COPY PLAIN" FontSize="9"
                                                            Padding="8,4" Tag="{Binding}" Click="CopyClipPlainClick" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        <StackPanel Grid.Row="2" Visibility="Collapsed">
                            <TextBlock Text="Q U I C K  R O U T E S" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource MutedTextBrush}" Margin="0,6,0,8" />
                            <Button Style="{StaticResource GhostButton}" HorizontalContentAlignment="Left">
                                <TextBlock Text="◇  Turn latest clip into a sticky" />
                            </Button>
                            <Button Style="{StaticResource GhostButton}" HorizontalContentAlignment="Left">
                                <TextBlock Text="⌁  File into a place" />
                            </Button>
                            <Button Style="{StaticResource GhostButton}" HorizontalContentAlignment="Left">
                                <TextBlock Text="≠  Compare two clips" />
                            </Button>
                        </StackPanel>
                        <Border Grid.Row="3" Background="#302A22" CornerRadius="10" Padding="12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✦" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,9,0" />
                                <TextBlock Text="AI stays off until you grant a plugin access." TextWrapping="Wrap"
                                           FontSize="10" Foreground="#C9BDAF" Width="236" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
