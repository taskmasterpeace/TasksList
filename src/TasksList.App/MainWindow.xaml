<Window x:Class="TasksList.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Task'sList" Width="1240" Height="780" MinWidth="980" MinHeight="620"
        WindowStartupLocation="CenterScreen" WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" AllowDrop="True" DragOver="MarkdownDragOver" Drop="MarkdownDrop">
    <Window.Resources>
        <Style x:Key="LibraryTab" TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="Margin" Value="0,0,5,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabRoot" Background="Transparent" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabRoot" Property="Background" Value="{StaticResource PrimarySoftBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabRoot" Property="Background" Value="{StaticResource CardHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        </Style>
        <Style x:Key="PanelCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="14" />
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource CanvasBrush}" BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1" CornerRadius="14">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="8" Opacity="0.45" Color="#000000" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="64" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Background="Transparent" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1" Cursor="Hand"
                    MouseLeftButtonDown="TitleBarMouseDown">
                <Grid Margin="20,0,10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Width="34" Height="34" Stretch="Uniform" SnapsToDevicePixels="True"
                               Source="/TasksList.App;component/Assets/app-icon-64.png" />
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Task'sList" FontSize="17" FontWeight="Bold" />
                            <TextBlock Text="Notes that stay with the work" FontSize="11"
                                       Foreground="{StaticResource MutedTextBrush}" />
                        </StackPanel>
                    </StackPanel>
                    <Border Grid.Column="1" Background="#202D29" CornerRadius="9" Padding="10,5"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock x:Name="StatusText" Text="LOCAL · PRIVATE" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource SuccessBrush}" />
                    </Border>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource GhostButton}" Content="—" Width="38" Height="36"
                                AutomationProperties.Name="Minimize" ToolTip="Minimize" Click="MinimizeClick" />
                        <Button Style="{StaticResource GhostButton}" Content="□" Width="38" Height="36"
                                AutomationProperties.Name="Maximize" ToolTip="Maximize" Click="MaximizeClick" />
                        <Button Style="{StaticResource GhostButton}" Content="×" Width="38" Height="36"
                                AutomationProperties.Name="Close" ToolTip="Close" Click="CloseClick" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,1,0">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Style="{StaticResource SectionLabel}" Text="QUICK ACTIONS" Margin="7,2,0,10" />
                        <StackPanel Grid.Row="1">
                            <Button Style="{StaticResource PrimaryButton}" Content="＋  New sticky"
                                    AutomationProperties.Name="New sticky" HorizontalContentAlignment="Left"
                                    Margin="0,0,0,7" Click="NewStickyClick" />
                            <Button Style="{StaticResource GhostButton}" Content="Clipboard palette   Ctrl+Shift+V"
                                    AutomationProperties.Name="Clipboard palette" HorizontalContentAlignment="Left"
                                    Click="ClipboardPaletteClick" />
                            <Button Style="{StaticResource GhostButton}" Content="Capture a region"
                                    HorizontalContentAlignment="Left" Click="CaptureRegionClick" />
                        </StackPanel>
                        <ScrollViewer Grid.Row="2" Margin="0,22,0,12" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Grid Margin="7,0,7,9">
                                    <TextBlock Style="{StaticResource SectionLabel}" Text="PLACES" />
                                    <Border HorizontalAlignment="Right" Background="{StaticResource PrimarySoftBrush}"
                                            CornerRadius="8" Padding="7,2">
                                        <TextBlock x:Name="NoteCountText" Text="0" FontSize="10" />
                                    </Border>
                                </Grid>
                                <ItemsControl x:Name="PlacesList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource GhostButton}" HorizontalContentAlignment="Left"
                                                    ToolTip="{Binding StableIdentity}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Prefix}" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,8,0" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Column="2" Text="{Binding KindLabel}" FontSize="9"
                                                               Foreground="{StaticResource MutedTextBrush}" Margin="7,2,0,0" />
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                        <StackPanel Grid.Row="3">
                            <Button Style="{StaticResource GhostButton}" Content="＋  New place"
                                    HorizontalContentAlignment="Left" Foreground="{StaticResource MutedTextBrush}" Click="NewPlaceClick" />
                            <Button Style="{StaticResource GhostButton}" Content="Plugins &amp; permissions"
                                    HorizontalContentAlignment="Left" Foreground="{StaticResource MutedTextBrush}" Click="PluginsClick" />
                        </StackPanel>
                    </Grid>
                </Border>

                <TabControl Grid.Column="1" Margin="24,18,24,24" Background="Transparent" BorderThickness="0"
                            ItemContainerStyle="{StaticResource LibraryTab}">
                    <TabItem Header="Notes">
                        <Grid Margin="0,18,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Your working notes" FontSize="26" FontWeight="Bold" />
                                    <TextBlock Text="Pinned, attached, searchable, and never buried." Margin="0,5,0,0"
                                               Foreground="{StaticResource MutedTextBrush}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Button Style="{StaticResource GhostButton}" Content="Drop .md here" IsHitTestVisible="False" Margin="0,0,8,0" />
                                    <Button Style="{StaticResource GhostButton}" Content="Apply style"
                                            Margin="0,0,8,0" Click="ApplyStyleToSelectedClick" />
                                    <Button Style="{StaticResource PrimaryButton}" Content="＋  New sticky" Click="NewStickyClick" />
                                </StackPanel>
                            </Grid>
                            <Grid Grid.Row="1" Margin="0,18,0,15">
                                <TextBox x:Name="SearchBox" Height="40" TextChanged="SearchTextChanged" ToolTip="Search notes" />
                                <TextBlock Text="Search titles and note text…" Foreground="{StaticResource MutedTextBrush}"
                                           Margin="12,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                            <Grid Grid.Row="2">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ListBox x:Name="NotesList" SelectionMode="Extended" Background="Transparent" BorderThickness="0">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate><WrapPanel ItemWidth="244" /></ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Padding" Value="0" />
                                                <Setter Property="Margin" Value="0" />
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="BorderThickness" Value="0" />
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border x:Name="SelectionFrame" CornerRadius="12" BorderThickness="2" BorderBrush="Transparent">
                                                                <ContentPresenter />
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter TargetName="SelectionFrame" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource GhostButton}" Padding="0" Margin="0,0,12,12"
                                                        Width="232" Height="184" HorizontalContentAlignment="Stretch"
                                                        VerticalContentAlignment="Stretch" Click="OpenNoteClick" Tag="{Binding}">
                                                    <Border Background="{Binding PaperBrush}" CornerRadius="10" Padding="15"
                                                            BorderBrush="{Binding EdgeBrush}" BorderThickness="1">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" />
                                                            </Grid.RowDefinitions>
                                                            <Grid>
                                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                                <TextBlock Text="{Binding Title}" Foreground="{Binding InkBrush}" FontWeight="Bold"
                                                                           FontSize="14" TextTrimming="CharacterEllipsis" />
                                                                <Ellipse Grid.Column="1" Width="7" Height="7" Fill="{Binding StatusBrush}" Margin="8,0,0,0" />
                                                            </Grid>
                                                            <TextBlock Grid.Row="1" Text="{Binding Preview}" Foreground="{Binding MutedInkBrush}"
                                                                       FontSize="12" TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                                                                       Margin="0,11,0,8" MaxHeight="86" />
                                                            <Grid Grid.Row="2">
                                                                <TextBlock Text="{Binding SourceLabel}" Foreground="{Binding MutedInkBrush}" FontSize="9" />
                                                                <TextBlock Text="OPEN ↗" HorizontalAlignment="Right" Foreground="{Binding InkBrush}"
                                                                           FontSize="9" FontWeight="Bold" />
                                                            </Grid>
                                                        </Grid>
                                                    </Border>
                                                </Button>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </ScrollViewer>
                                <TextBlock Text="No notes match this view. Create a sticky or drop in a Markdown file."
                                           Foreground="{StaticResource MutedTextBrush}" FontSize="14"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers><DataTrigger Binding="{Binding HasItems, ElementName=NotesList}" Value="False"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Clipboard">
                        <Grid Margin="0,18,0,0">
                            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="Clipboard history" FontSize="26" FontWeight="Bold" />
                                    <TextBlock Text="Source-aware, searchable, and ready to route into notes and places."
                                               Margin="0,5,0,0" Foreground="{StaticResource MutedTextBrush}" />
                                </StackPanel>
                                <Button Style="{StaticResource PrimaryButton}" Content="Open command palette   Ctrl+Shift+V"
                                        HorizontalAlignment="Right" VerticalAlignment="Center" Click="ClipboardPaletteClick" />
                            </Grid>
                            <Grid Grid.Row="1" Margin="0,18,0,0">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="ClipboardList">
                                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel ItemWidth="310" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource PanelCard}" Width="298" MinHeight="142" Margin="0,0,12,12">
                                                    <StackPanel>
                                                        <Grid>
                                                            <TextBlock Text="{Binding FormatLabel}" FontSize="9" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" />
                                                            <TextBlock Text="{Binding TimeLabel}" HorizontalAlignment="Right" FontSize="9" Foreground="{StaticResource MutedTextBrush}" />
                                                        </Grid>
                                                        <TextBlock Text="{Binding Preview}" TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                                                                   MaxHeight="54" FontSize="12" Margin="0,9,0,8" />
                                                        <TextBlock Text="{Binding SourceLabel}" TextTrimming="CharacterEllipsis" FontSize="9"
                                                                   Foreground="{StaticResource MutedTextBrush}" />
                                                        <StackPanel Orientation="Horizontal" Margin="0,9,0,0">
                                                            <Button Style="{StaticResource GhostButton}" Content="MAKE NOTE" FontSize="9" Padding="8,4"
                                                                    Margin="0,0,4,0" Tag="{Binding}" Click="ClipToNoteClick" />
                                                            <Button Style="{StaticResource GhostButton}" Content="COPY PLAIN" FontSize="9" Padding="8,4"
                                                                    Tag="{Binding}" Click="CopyClipPlainClick" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                                <TextBlock Text="Clipboard history is empty. Copy text, an image, or files to begin."
                                           Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">
                                    <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding HasItems, ElementName=ClipboardList}" Value="False"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Contexts">
                        <Grid Margin="0,18,0,0">
                            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="Work contexts" FontSize="26" FontWeight="Bold" />
                                    <TextBlock Text="Applications, windows, conversations, and live browser tabs your work came from."
                                               Margin="0,5,0,0" Foreground="{StaticResource MutedTextBrush}" />
                                </StackPanel>
                                <Button Style="{StaticResource PrimaryButton}" Content="＋  New manual place" HorizontalAlignment="Right"
                                        VerticalAlignment="Center" Click="NewPlaceClick" />
                            </Grid>
                            <Grid Grid.Row="1" Margin="0,18,0,0">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="ContextsList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource PanelCard}" Margin="0,0,0,10">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="42" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                        <Border Width="34" Height="34" CornerRadius="10" Background="{StaticResource PrimarySoftBrush}">
                                                            <TextBlock Text="{Binding Initial}" Foreground="{StaticResource PrimaryBrush}" FontWeight="Bold"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Border>
                                                        <StackPanel Grid.Column="1" Margin="10,0,14,0">
                                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" />
                                                            <TextBlock Text="{Binding Detail}" Foreground="{StaticResource MutedTextBrush}" FontSize="11"
                                                                       TextTrimming="CharacterEllipsis" Margin="0,3,0,0" />
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding KindLabel}" FontSize="10" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Right" />
                                                            <TextBlock Text="LIVE" FontSize="9" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Right">
                                                                <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding IsLive}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                                <TextBlock x:Name="ContextsEmptyText" Text="No application contexts yet. Attach a sticky or copy from an application to add one."
                                           TextWrapping="Wrap" TextAlignment="Center" Foreground="{StaticResource MutedTextBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="430" IsHitTestVisible="False">
                                    <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding HasItems, ElementName=ContextsList}" Value="False"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Extensions">
                        <Grid Margin="0,18,0,0">
                            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="Extensions" FontSize="26" FontWeight="Bold" />
                                    <TextBlock Text="Local plugins declare every capability before Task'sList grants access."
                                               Margin="0,5,0,0" Foreground="{StaticResource MutedTextBrush}" />
                                </StackPanel>
                                <Button Style="{StaticResource PrimaryButton}" Content="Plugins &amp; permissions" HorizontalAlignment="Right"
                                        VerticalAlignment="Center" Click="PluginsClick" />
                            </Grid>
                            <Grid Grid.Row="1" Margin="0,18,0,0">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="ExtensionsList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource PanelCard}" Margin="0,0,0,10">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="42" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                        <Border Width="34" Height="34" CornerRadius="10" Background="#32304A">
                                                            <TextBlock Text="{Binding Initial}" Foreground="#C8B8FF" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Border>
                                                        <StackPanel Grid.Column="1" Margin="10,0,14,0">
                                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" />
                                                            <TextBlock Text="{Binding CapabilityLabel}" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,3,0,0" />
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="2" Text="{Binding VersionLabel}" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                                <TextBlock x:Name="ExtensionsEmptyText" Text="No plugins installed. Open Plugins &amp; permissions to install a local package."
                                           TextWrapping="Wrap" TextAlignment="Center" Foreground="{StaticResource MutedTextBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="430" IsHitTestVisible="False">
                                    <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding HasItems, ElementName=ExtensionsList}" Value="False"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                                </TextBlock>
                            </Grid>
                            <Border Grid.Row="2" Background="#202D29" CornerRadius="10" Padding="12" Margin="0,14,0,0">
                                <TextBlock Text="AI and page-reading permissions remain off unless an installed plugin requests them and you grant access."
                                           Foreground="#BAD9CC" FontSize="11" />
                            </Border>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Trash">
                        <Grid Margin="0,18,0,0">
                            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                            <StackPanel>
                                <TextBlock Text="Trash" FontSize="26" FontWeight="Bold" />
                                <TextBlock Text="Restore anything immediately. Permanent deletion unlocks after 30 days."
                                           Margin="0,5,0,0" Foreground="{StaticResource MutedTextBrush}" />
                            </StackPanel>
                            <Grid Grid.Row="1" Margin="0,18,0,0">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="TrashList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource PanelCard}" Margin="0,0,0,10">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14" />
                                                            <TextBlock Text="{Binding Detail}" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,3,0,0" />
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                            <Button Style="{StaticResource GhostButton}" Content="Restore" Tag="{Binding}" Click="RestoreTrashClick" />
                                                            <Button Style="{StaticResource GhostButton}" Content="Delete forever" Foreground="#E99A91"
                                                                    IsEnabled="{Binding CanDeletePermanently}" ToolTip="{Binding DeleteHint}"
                                                                    Tag="{Binding}" Click="DeleteTrashPermanentlyClick" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                                <TextBlock Text="Trash is empty." Foreground="{StaticResource MutedTextBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">
                                    <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding HasItems, ElementName=TrashList}" Value="False"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Grid>

            <Border x:Name="CaptureNotice" Grid.RowSpan="2" Panel.ZIndex="20"
                    Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Bottom"
                    Margin="24" Padding="14,10" CornerRadius="8"
                    Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" AutomationProperties.LiveSetting="Polite">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Screenshot copied to clipboard" VerticalAlignment="Center" />
                    <Button Style="{StaticResource GhostButton}" Content="Create note"
                            Margin="12,0,0,0" Click="CreateCapturedNoteClick" />
                    <Button Style="{StaticResource GhostButton}" Content="Dismiss"
                            Margin="4,0,0,0" Click="DismissCaptureNoticeClick" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
