<Window x:Class="TasksList.App.Places.NewPlaceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New place"
        Width="420" Height="280"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        AllowsTransparency="False"
        Background="{StaticResource PanelBrush}">
    <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0" CornerRadius="0" Padding="22">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Text="Create a place" FontSize="21" FontWeight="Bold" />
            <TextBlock Grid.Row="1" Text="Use places to file clips, notes, saved tabs, and related work."
                       Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,5,0,16" />
            <StackPanel Grid.Row="2">
                <TextBlock Text="NAME" FontSize="9" FontWeight="Bold" Foreground="{StaticResource MutedTextBrush}" />
                <TextBox x:Name="NameBox" Margin="0,5,0,12" AutomationProperties.Name="Place name" />
                <TextBlock Text="PARENT" FontSize="9" FontWeight="Bold" Foreground="{StaticResource MutedTextBrush}" />
                <ComboBox x:Name="ParentBox" Margin="0,5,0,0" Padding="9,6" DisplayMemberPath="Name"
                          AutomationProperties.Name="Parent place"
                          Background="{StaticResource CardBrush}" Foreground="{StaticResource TextBrush}" />
            </StackPanel>
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Style="{StaticResource GhostButton}" Content="Cancel" Margin="0,0,8,0" Click="CancelClick" />
                <Button Style="{StaticResource PrimaryButton}" Content="Create place" Click="CreateClick" />
            </StackPanel>
        </Grid>
    </Border>
</Window>

