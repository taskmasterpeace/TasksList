{
  "manifest_version": 3,
  "name": "Task'sList Browser Context",
  "version": "1.0.0",
  "description": "Attaches Task'sList notes, clipboard captures, and saved sessions to browser tabs and conversations.",
  "key": "",
  "permissions": ["tabs", "nativeMessaging", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "action": {
    "default_title": "Task'sList Browser Context"
  },
  "incognito": "not_allowed"
}
